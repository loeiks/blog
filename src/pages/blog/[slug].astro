---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Link from "~/components/html/Link.astro";
import Img from "~/components/html/Img.astro";

export const getStaticPaths = async () => {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.data.customSlug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | @loeiks`}
  description={post.data.description}
>
  <article class="flex flex-col gap-4">
    <div class="flex flex-col">
      <time
        datetime={post.data.publishDate.toISOString()}
        class="text-gray-600 mb-1"
      >
        {
          post.data.publishDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
      <h1 class="text-4xl font-bold">{post.data.title}</h1>
    </div>

    <div
      class="prose w-[calc(100vw-var(--spacing)*8)] prose-p:text-[#282828] prose-ol:text-[#282828] prose-ul:text-[#282828] prose-li:text-[#282828] marker:text-[#282828] prose-h2:mt-6 prose-h2:mb-4 prose-hr:my-6 max-w-maxw"
    >
      <Content components={{ a: Link, img: Img }} />
    </div>
  </article>
</BaseLayout>
